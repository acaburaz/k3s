pipeline {
  agent any

  options {
    disableConcurrentBuilds()
  }

  stages {
    stage('Checkout') {
      steps {
        checkout([$class: 'GitSCM', branches: [[name: '*/develop']],
          userRemoteConfigs: [[url: 'https://dev.azure.com/logiplan/LogiPlanWebApp/_git/LogiPlanWebApp',
          credentialsId: 'logiplan-scm']]])
      }
    }
    stage('Build & Push Image') {
      steps {
        withCredentials([usernamePassword(credentialsId: 'ghcr-credentials',
            usernameVariable: 'GHCR_USER', passwordVariable: 'GHCR_TOKEN')]) {
          sh '''
            echo "$GHCR_TOKEN" | docker login ghcr.io -u "$GHCR_USER" --password-stdin
            docker build -t ghcr.io/acaburaz/logiplan-webapi:$BUILD_NUMBER \
                         -t ghcr.io/acaburaz/logiplan-webapi:latest .
            docker push ghcr.io/acaburaz/logiplan-webapi:$BUILD_NUMBER
            docker push ghcr.io/acaburaz/logiplan-webapi:latest
          '''
        }
      }
    }
    stage('Update Image Tag') {
      steps {
        withCredentials([usernamePassword(credentialsId: 'github-credentials',
            usernameVariable: 'GH_USER', passwordVariable: 'GH_TOKEN')]) {
          sh '''
            git clone https://$GH_USER:$GH_TOKEN@github.com/acaburaz/k3s.git /tmp/gitops-api-$BUILD_NUMBER
            cd /tmp/gitops-api-$BUILD_NUMBER
            sed -i "s|image: ghcr.io/acaburaz/logiplan-webapi:.*|image: ghcr.io/acaburaz/logiplan-webapi:$BUILD_NUMBER|" apps/logiplan-api/deployment.yaml
            git config user.email "jenkins@ci" && git config user.name "Jenkins"
            git add apps/logiplan-api/deployment.yaml
            git commit -m "ci: update logiplan-webapi to build $BUILD_NUMBER" || echo "No changes"
            git push || true
            rm -rf /tmp/gitops-api-$BUILD_NUMBER
          '''
        }
      }
    }
  }
  post {
    failure { echo "Build failed for logiplan-api #${BUILD_NUMBER}" }
    success {
      echo "Deployed logiplan-webapi:${BUILD_NUMBER}"
      withCredentials([usernamePassword(credentialsId: 'ghcr-credentials',
          usernameVariable: 'GHCR_USER', passwordVariable: 'GHCR_TOKEN')]) {
        sh '''
          curl -s -H "Authorization: Bearer $GHCR_TOKEN" \
            "https://api.github.com/user/packages/container/logiplan-webapi/versions?per_page=100" | \
            grep -oE '"id":[0-9]+' | grep -oE '[0-9]+' | tail -n +6 | \
            while read VID; do
              curl -s -X DELETE -H "Authorization: Bearer $GHCR_TOKEN" \
                "https://api.github.com/user/packages/container/logiplan-webapi/versions/$VID" || true
            done
        '''
      }
    }
  }
}
